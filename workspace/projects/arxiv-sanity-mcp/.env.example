# arxiv-mcp configuration
# Copy to .env and adjust values for your environment

# PostgreSQL connection URL (async driver)
DATABASE_URL=postgresql+asyncpg://arxiv_mcp:arxiv_mcp_dev@localhost:5432/arxiv_mcp

# Test database (used by pytest fixtures)
TEST_DATABASE_URL=postgresql+asyncpg://arxiv_mcp:arxiv_mcp_dev@localhost:5432/arxiv_mcp_test

# arXiv OAI-PMH endpoint (changed March 2025)
# ARXIV_OAI_URL=https://oaipmh.arxiv.org/oai

# arXiv search API endpoint
# ARXIV_API_URL=http://export.arxiv.org/api/query

# Rate limit: seconds between arXiv API requests
# HARVEST_RATE_LIMIT=3.0

# Pagination defaults
# DEFAULT_PAGE_SIZE=20
# MAX_PAGE_SIZE=100
